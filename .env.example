# Runtime mode:
# - jwks: verify access tokens with OIDC issuer and JWKS.
# - dev: decode local unsecured JWTs created by /api/dev-token. Use only for offline demos.
# - NO_SECURITY=true: bypass all JWT validation and use a static demo user/token.
NO_SECURITY=false
AUTH_MODE=jwks
DEV_AUTH_ENABLED=false

# Service ports and URLs
PORTAL_PORT=3000
AGENT_PORT=3001
MCP_PORT=3002
AGENT_URL=http://localhost:3001
MCP_URL=http://localhost:3002/mcp
ALLOWED_ORIGINS=http://localhost:3000

# Optional audience validation per service. Leave empty to skip aud validation.
API_EXPECTED_AUDIENCE=
AGENT_EXPECTED_AUDIENCE=
MCP_EXPECTED_AUDIENCE=

# Scope requested when the portal exchanges the user access token for an agent API token.
AGENT_TOKEN_EXCHANGE_SCOPE=

# OAuth client used by the portal API backend for token exchange.
API_OAUTH_CLIENT_ID=
API_OAUTH_CLIENT_SECRET=

# Scope and OAuth client used by the agent backend for token exchange before MCP calls.
MCP_TOKEN_EXCHANGE_SCOPE=customer-support-agent:customer-mcp:profile:read customer-support-agent:customer-mcp:payments:read
AGENT_OAUTH_CLIENT_ID=
AGENT_OAUTH_CLIENT_SECRET=

# Generic OIDC settings. Prefer discovery metadata for PingOne and other OIDC providers.
OIDC_DISCOVERY_URI=https://auth.pingone.com/YOUR_ENVIRONMENT_ID/as/.well-known/openid-configuration
OIDC_CLIENT_ID=YOUR_CLIENT_ID
# Required when the PingOne app is configured as a confidential web app.
# Leave unset for a public PKCE app.
# OIDC_CLIENT_SECRET=YOUR_CLIENT_SECRET
OIDC_REDIRECT_URI=http://localhost:3000/callback
OIDC_SCOPES=openid profile customer-support-agent:customer-mcp:profile:read customer-support-agent:customer-mcp:payments:read

# CIBA settings for payment approval.
CIBA_CLIENT_ID=
CIBA_CLIENT_SECRET=
CIBA_SCOPE=openid
CIBA_MOCK_APPROVAL_SECONDS=8
